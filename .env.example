# Copy to .env and fill in values. Never commit .env.

# Required: Bearer token for the EZLoot import endpoint
EZLOOT_IMPORT_TOKEN=changeme

# Optional: override the import URL for local testing
# EZLOOT_IMPORT_URL=http://localhost:3000/api/admin/pricing-intel/import

# Optional tuning
SCRAPE_INTERVAL_MINUTES=30
PORT=8080
LOG_LEVEL=info
